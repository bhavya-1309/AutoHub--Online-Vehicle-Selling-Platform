<%- include('../partials/header') %>
<div class="form-page">
  <h2>Book a Test Drive</h2>

  <div class="booking-summary">
    <% if (listing.images && listing.images.length > 0) { %>
      <img src="<%= listing.images[0] %>" alt="<%= listing.title %>" class="booking-thumb"/>
    <% } %>
    <div>
      <h3><%= listing.title %></h3>
      <p><%= listing.brand %> <%= listing.model %> &bull; <%= listing.year %></p>
      <p class="price">₹<%= listing.price.toLocaleString('en-IN') %></p>
      <p>Seller: <strong><%= listing.seller.name %></strong></p>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <form method="POST" action="/appointments" class="listing-form">
    <input type="hidden" name="listingId" value="<%= listing._id %>"/>

    <div class="form-row two-col">
      <div class="form-group">
        <label>Preferred Date *</label>
        <input type="date" name="date" required min="<%= new Date().toISOString().split('T')[0] %>"/>
      </div>
      <div class="form-group">
        <label>Preferred Time *</label>
        <select name="time" required>
          <option value="">Select a time slot</option>
          <% ['9:00 AM','10:00 AM','11:00 AM','12:00 PM','1:00 PM','2:00 PM','3:00 PM','4:00 PM','5:00 PM','6:00 PM'].forEach(t => { %>
            <option value="<%= t %>"><%= t %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Message to Seller (optional)</label>
      <textarea name="message" rows="3" placeholder="Any questions or special requests for the seller..."></textarea>
    </div>

    <div class="action-btns">
      <button type="submit" class="btn-primary">📅 Confirm Booking</button>
      <a href="/listings/<%= listing._id %>" class="btn-outline">Back</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
